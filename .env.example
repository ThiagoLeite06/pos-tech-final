# .env.example — Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.
#
# QUICKSTART: Run ./docker/generate-keys.sh to generate JWT keys automatically.
# The script writes JWT_PRIVATE_KEY and JWT_PUBLIC_KEY to .env.

# ── RSA Key Pair for JWT RS256 ─────────────────────────────────────────────
# Format: raw Base64 (no PEM headers), PKCS8 DER (private), X.509 DER (public)
# Generate with: ./docker/generate-keys.sh
JWT_PRIVATE_KEY=<run ./docker/generate-keys.sh>
JWT_PUBLIC_KEY=<run ./docker/generate-keys.sh>

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# These match the hardcoded values in docker-compose.yml.
# Override here only if you need a different password in your environment.
# DB_PASSWORD=susreceita123
